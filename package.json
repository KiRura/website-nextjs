{
	"name": "website-nextjs",
	"version": "0.1.0",
	"scripts": {
		"dev": "next dev --webpack",
		"dev:build": "bun run dep:gen && next build --webpack",
		"build": "chakra typegen ./src/theme/index.ts && bun run dev:build",
		"start": "next start",
		"lint": "biome lint && tsc",
		"check": "biome check && tsc",
		"check:fix": "biome check --write --unsafe && tsc",
		"dep:gen": "license-report --only=prod --config license-report-config.json > src/app/license/licenses.json",
	},
	"dependencies": {
		"@chakra-ui/react": "^3.31.0",
		"@emotion/react": "^11.14.0",
		"@opennextjs/cloudflare": "^1.14.9",
		"@supabase/supabase-js": "2.90.1",
		"date-fns": "^4.1.0",
		"microcms-js-sdk": "^3.2.0",
		"next": "^16.1.3",
		"next-themes": "^0.4.6",
		"next-turnstile": "^1.0.7",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-icons": "^5.5.0",
		"swr": "^2.3.8",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@chakra-ui/cli": "^3.31.0",
		"@types/node": "^25.0.9",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"license-report": "^6.8.1",
		"typescript": "^5.9.3",
		"wrangler": "^4.59.2"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@vercel/speed-insights",
		"esbuild",
		"rclone.js",
		"sharp",
		"workerd"
	],
	"engines": {
		"node": ">=22"
	}
}
